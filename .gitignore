# dependencies
node_modules/

# build output
dist/
dist-ssr/

# generated optimized media (regenerated by `npm run content`)
public/assets/

# logs / local
*.local
*.log
npm-debug.log*

# editor / os
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/

# fetched 3D models (regenerable via fetch-models + models)
content/**/model.glb
content/models/

# raw source media — large originals (several > GitHub's 100MB limit) live on
# disk / Tigris, not git. Optimized derivatives are generated into public/assets.
content/projects/**/imports/

# throwaway dev iteration screenshots (reference captures are kept)
__resources__/portfolio-dev/

# Playwright output
test-results/
playwright-report/
blob-report/
